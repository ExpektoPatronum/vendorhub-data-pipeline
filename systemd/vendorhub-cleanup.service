[Unit]
Description=VendorHub Staging Cleanup Job
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/opt/vendor-sync/app
EnvironmentFile=/opt/vendor-sync/.env
ExecStart=/opt/vendor-sync/app/venv/bin/python -m vendorhub.cli.run_cleanup
User=root
Group=root
